knitr::opts_chunk$set(echo = TRUE, warning = FALSE, message = FALSE)
library(arules)
library(arulesViz)
data(Groceries)
Groceries
summary(Groceries)
itemFrequency(Groceries)[1:10]
itemFrequencyPlot(Groceries, topN = 20, type = "absolute")
itemsets_freq <- apriori(
Groceries,
parameter = list(
target = "frequent itemsets",
supp = 0.01,
minlen = 2
)
)
itemsets_freq
inspect(head(sort(itemsets_freq, by = "support"), 10))
itemsets_df <- as(itemsets_freq, "data.frame")
head(itemsets_df)
summary(itemsets_df$support)
rules <- apriori(
Groceries,
parameter = list(
supp = 0.01,
conf = 0.3
)
)
rules
summary(rules)
inspect(head(sort(rules, by = "lift"), 10))
rules_filtered <- subset(
rules,
subset = lift > 1.5 & confidence > 0.5
)
inspect(rules_filtered)
plot(
rules_filtered,
method = "scatterplot",
measure = c("support", "confidence"),
shading = "lift"
)
plot(
rules_filtered,
method = "graph",
engine = "htmlwidget"
)
data(iris)
par(mfrow = c(1,2))
# Dispersión con recta ajustada
plot(iris$Petal.Length, iris$Sepal.Length,
main="Relación entre Petal.Length y Sepal.Length",
xlab="Petal.Length",
ylab="Sepal.Length")
abline(modelo_lineal, col="red", lwd=2)
# Residuos vs valores ajustados
plot(modelo_lineal$fitted.values,
resid(modelo_lineal),
main="Residuos vs Ajustados",
xlab="Valores ajustados",
ylab="Residuos")
modelo_lineal <- lm(Sepal.Length ~ Petal.Length, data = iris)
summary(modelo_lineal)
# Residuos vs valores ajustados
plot(modelo_lineal$fitted.values,
resid(modelo_lineal),
main="Residuos vs Ajustados",
xlab="Valores ajustados",
ylab="Residuos")
plot(iris$Petal.Length, iris$Sepal.Length,
xlab="Petal.Length",
ylab="Sepal.Length",
main="Scatterplot")
cor(iris$Petal.Length, iris$Sepal.Length)
cor.test(iris$Petal.Length, iris$Sepal.Length)
plot(iris$Petal.Length, iris$Sepal.Length)
lines(lowess(iris$Petal.Length, iris$Sepal.Length), col="blue", lwd=2)
modelo <- lm(Sepal.Length ~ Petal.Length, data=iris)
summary(modelo)
