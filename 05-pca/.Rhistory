knitr::opts_chunk$set(echo = TRUE)
library(psych)
library(REdaS)
library(grid)
datos <- read.csv("sample-pca.csv")
head(datos)
summary(datos)
datos_num <- datos[, sapply(datos, is.numeric)]
KMO(datos_num)
bart_spher(datos_num)
datos_std <- scale(datos_num)
apply(datos_std, 2, mean)
apply(datos_std, 2, sd)
cov_matrix <- cov(datos_std)
cov_matrix
eig <- eigen(cov_matrix)
eig$values
eig$vectors
var_exp <- eig$values / sum(eig$values)
var_exp
cumsum(var_exp)
plot(eig$values, type="b", pch=19,
xlab="Componente Principal",
ylab="Eigenvalor",
main="Scree Plot")
Z <- datos_std %*% eig$vectors
head(Z)
# Dirección del primer componente
pc1 <- eig$vectors[,1]
# Coordenadas proyectadas en el espacio original
proj_coords <- Z[,1] %*% t(pc1)
# Graficar las dos primeras variables estandarizadas
plot(datos_std[,1], datos_std[,2],
pch = 19,
col = rgb(0.6,0.2,0.6,0.6),
xlab = colnames(datos_std)[1],
ylab = colnames(datos_std)[2],
main = "Proyección sobre el Primer Componente")
# Dibujar eje PC1
arrows(0, 0,
pc1[1]*4, pc1[2]*4,
col = "red",
lwd = 3,
length = 0.1)
# Líneas de proyección
for(i in 1:nrow(datos_std)){
segments(datos_std[i,1], datos_std[i,2],
proj_coords[i,1], proj_coords[i,2],
col = "gray",
lty = 2)
}
# Puntos proyectados
points(proj_coords[,1], proj_coords[,2],
col = "red",
pch = 19)
# Extraer primeras dos componentes
pc1_vals <- Z[,1]
pc2_vals <- Z[,2]
# Crear posiciones verticales separadas
y_pc1 <- rep(2, length(pc1_vals))
y_pc2 <- rep(1, length(pc2_vals))
plot(pc1_vals, y_pc1,
pch = 19,
col = rgb(1,0,0,0.5),
xlab = "Valor del Componente",
ylab = "",
yaxt = "n",
main = "Visualización de Componentes Principales",
xlim = range(c(pc1_vals, pc2_vals)))
points(pc2_vals, y_pc2,
pch = 19,
col = rgb(0,0,1,0.5))
axis(2, at = c(1,2),
labels = c("PC2", "PC1"))
# Extraer primeras dos componentes
pc1_vals <- Z[,1]
pc2_vals <- Z[,2]
# Crear posiciones verticales separadas
y_pc1 <- rep(2, length(pc1_vals))
y_pc2 <- rep(1, length(pc2_vals))
plot(pc1_vals, y_pc1,
pch = 19,
col = rgb(1,0,0,0.5),
xlab = "Valor del Componente",
ylab = "",
yaxt = "n",
main = "Visualización de Componentes Principales",
xlim = range(c(pc1_vals, pc2_vals)))
points(pc2_vals, y_pc2,
pch = 19,
col = rgb(0,0,1,0.5))
axis(2, at = c(1,2),
labels = c("PC2", "PC1"))
abline(h=1, col="gray", lty=2)
abline(h=2, col="gray", lty=2)
pc1_vals <- Z[,1]
pc2_vals <- Z[,2]
y_pc1 <- rep(2, length(pc1_vals))
y_pc2 <- rep(1, length(pc2_vals))
plot(pc1_vals, y_pc1,
pch = 19,
col = rgb(1,0,0,0.5),
xlab = "Valor del Componente",
ylab = "",
yaxt = "n",
main = "Visualización de Componentes Principales",
xlim = range(c(pc1_vals, pc2_vals)))
points(pc2_vals, y_pc2,
pch = 19,
col = rgb(0,0,1,0.5))
axis(2, at = c(1,2),
labels = c("PC2", "PC1"))
plot(cumsum(var_exp), type="b", pch=19,
xlab="Número de componentes",
ylab="Varianza acumulada",
ylim=c(0,1),
main="Varianza explicada acumulada")
abline(h=0.8, col="red", lty=2)
biplot(prcomp(datos_std))
barplot(eig$vectors[,1],
main="Cargas en PC1",
col="steelblue")
heatmap(cor(datos_std), symm=TRUE)
plot(Z[,1], Z[,2],
xlab="PC1",
ylab="PC2",
pch=19)
pc1_vals <- Z[,1]
pc2_vals <- Z[,2]
y_pc1 <- rep(2, length(pc1_vals))
y_pc2 <- rep(1, length(pc2_vals))
plot(pc1_vals, y_pc1,
pch = 19,
col = rgb(1,0,0,0.5),
xlab = "Valor del Componente",
ylab = "",
yaxt = "n",
main = "Visualización de Componentes Principales",
xlim = range(c(pc1_vals, pc2_vals)))
points(pc2_vals, y_pc2,
pch = 19,
col = rgb(0,0,1,0.5))
axis(2, at = c(1,2),
labels = c("PC2", "PC1"))
contrib <- eig$vectors^2
barplot(contrib[,1],
main="Contribución relativa a PC1")
matriz <- cor(datos[ , -1], use = "pairwise.complete.obs")
matriz <- cor(datos_num, use = "pairwise.complete.obs")
corrplot(matriz,
method = "color",
type = "upper",
addCoef.col = "black",
tl.col = "black",
tl.srt = 45,
col = colorRampPalette(c("blue","white","red"))(200))
library(psych)
library(REdaS)
library(grid)
library(corrplot)
matriz <- cor(datos[ , -1], use = "pairwise.complete.obs")
matriz <- cor(datos_num, use = "pairwise.complete.obs")
corrplot(matriz,
method = "color",
type = "upper",
addCoef.col = "black",
tl.col = "black",
tl.srt = 45,
col = colorRampPalette(c("blue","white","red"))(200))
matriz <- cor(datos[ , -1], use = "pairwise.complete.obs")
matriz <- cor(datos_num, use = "pairwise.complete.obs")
corrplot(matriz,
method = "color",
type = "upper",
addCoef.col = "black",
tl.col = "black",
tl.srt = 45,
col = colorRampPalette(c("blue","white","red"))(200))
corrplot(matriz,
method = "color",
order = "hclust",
addCoef.col = "black",
tl.col = "black")
fviz_pca_var(compPrinc,
col.var = "cos2",
gradient.cols = c("#00AFBB", "#E7B800", "#FC4E07"),
repel = TRUE)
